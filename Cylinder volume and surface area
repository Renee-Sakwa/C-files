#include <iostream>
#include <cmath>
using namespace std;

int main() {
    double r, h, vol, sa;
    const double PI = 3.14159;

    cout << "Enter radius and height: "; cin >> r >> h; 
    vol = PI * r * r * h; 
    sa = (2 * PI * r * r) + (2 * PI * r * h); 

    cout << "Volume: " << vol << "\nSurface Area: " << sa << endl;
    return 0;
}
